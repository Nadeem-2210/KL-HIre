PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/interview_platform

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Judge0 API (get from rapidapi.com/judge0-official)
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your_judge0_rapidapi_key

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Storage (local or s3)
STORAGE_TYPE=local
UPLOAD_DIR=uploads

# AWS S3 (only needed if STORAGE_TYPE=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Groq (optional but recommended for transcription)
GROQ_API_KEY=your_groq_api_key_here

# Team Analysis API (Required for evaluation reports)
TEAM_ANALYSIS_API_URL=https://mahimadangi-ai-hiring-evaluator.hf.space/generate-report
TEAM_ANALYSIS_API_KEY=your_api_key_here

# Admin registration security key
ADMIN_REGISTRATION_KEY=admin123

